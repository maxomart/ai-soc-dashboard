# --- AI SOC Dashboard environment ---
# Everything works out of the box in DEMO MODE with no variables set:
# security events are simulated server-side and AI triage uses a built-in
# mock engine. Provide a key below to enable live OpenAI-powered triage.

# Optional. When set, high/critical alerts are triaged by the OpenAI API.
# When unset, a realistic mock triage is generated instead.
OPENAI_API_KEY=

# Optional. Chat model used for triage. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini
